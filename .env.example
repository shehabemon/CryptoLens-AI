# Google Gemini API key for CryptoLens-AI Intelligence Terminal (free at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL connection string
DATABASE_URL=postgresql://cryptolens:cryptolens_dev@localhost:5432/cryptolens

# JWT secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_min_32_chars_long_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars_long

# Server
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:8080
